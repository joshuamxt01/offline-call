# ============================================================================
# Nexa backend environment — copy to .env and fill in.
# Local dev defaults work with infra/docker-compose.dev.yml out of the box.
# ============================================================================

NODE_ENV=development
PORT=4000

# Comma-separated allowed origins for CORS + Socket.IO (web app)
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL (Neon in prod) -----------------------------------------------
# Local docker:  postgres://nexa:nexa@localhost:5432/nexa
# Neon (prod):   postgres://USER:PASSWORD@ep-xxx.neon.tech/nexa?sslmode=require
DATABASE_URL=postgres://nexa:nexa@localhost:5432/nexa

# --- Redis (Upstash in prod) -------------------------------------------------
# Local docker:  redis://localhost:6379
# Upstash (prod): rediss://default:PASSWORD@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# --- JWT ---------------------------------------------------------------------
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TOKEN_TTL=900          # seconds (15 min)
REFRESH_TOKEN_TTL=2592000     # seconds (30 days)

# --- TURN (coturn) -----------------------------------------------------------
# Must match static-auth-secret in infra/coturn/turnserver.conf
TURN_SECRET=CHANGE_ME_MATCH_BACKEND_TURN_SECRET
TURN_URLS=stun:localhost:3478,turn:localhost:3478
TURN_TTL=86400

# --- Object storage (Backblaze B2, S3-compatible) ----------------------------
# Backblaze B2 (prod):
#   S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
#   S3_REGION=us-west-004
# Local MinIO (dev):  http://localhost:9000
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=nexa-media
S3_ACCESS_KEY_ID=nexa
S3_SECRET_ACCESS_KEY=nexa-secret
S3_FORCE_PATH_STYLE=true       # true for MinIO/B2 S3 endpoint

# --- Rate limiting -----------------------------------------------------------
RATE_LIMIT_WINDOW=60           # seconds
RATE_LIMIT_MAX=120             # requests per window (default bucket)
