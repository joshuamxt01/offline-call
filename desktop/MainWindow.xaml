<Window x:Class="Nexa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Nexa" Height="820" Width="1200" WindowStartupLocation="CenterScreen"
        Background="#0B0F1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0B0F1A" Padding="12,7">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Nexa" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="ServerLabel" Foreground="#9AA0B0" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Content="Change server" Click="ChangeServer_Click" Padding="8,3" Margin="0,0,8,0"/>
                <Button Content="Reload" Click="Reload_Click" Padding="8,3"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="Web" />

            <!-- Always-visible WPF overlay so the window is never "just black":
                 shows loading state while WebView2 starts / connects, and a clear
                 error if the server can't be reached. Hidden once the page loads. -->
            <Border x:Name="LoadingOverlay" Background="#0B0F1A">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                    <TextBlock Text="Nexa" Foreground="White" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoadingText" Text="Starting…" Foreground="#9AA0B0" FontSize="13"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,18"/>
                    <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Width="240" Height="4"
                                 Foreground="#4F7CFF" Background="#222A3D" BorderThickness="0"/>
                    <StackPanel x:Name="ErrorActions" Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="0,20,0,0" Visibility="Collapsed">
                        <Button Content="Change server" Click="ChangeServer_Click" Padding="12,5" Margin="0,0,10,0"/>
                        <Button Content="Retry" Click="Reload_Click" Padding="12,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
