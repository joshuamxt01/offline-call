[
  {
    "corsRuleName": "nexaWeb",
    "allowedOrigins": [
      "http://localhost:3000",
      "https://YOUR-WEB-DOMAIN"
    ],
    "allowedOperations": [
      "s3_put",
      "s3_get",
      "s3_head"
    ],
    "allowedHeaders": ["*"],
    "exposeHeaders": ["etag"],
    "maxAgeSeconds": 3600
  }
]
